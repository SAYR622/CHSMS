<Window x:Class="VisitorInterface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Visitor Dashboard"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F2F6">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
        <Border Grid.Column="0">

            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1F2232" Offset="0"/>
                    <GradientStop Color="#363B57" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel Margin="30">

                <TextBlock Text="VISITOR INTERFACE"
                           FontSize="42"
                           Foreground="White"
                           Margin="0,0,0,50"/>

                <StackPanel Orientation="Horizontal">

                    <Ellipse Width="70"
                             Height="70"
                             Fill="#E4E4E4"/>

                    <StackPanel Margin="15,5,0,0">

                        <TextBlock Text="Welcome"
                                   Foreground="White"
                                   FontSize="22"/>

                        <TextBlock Text="Visitor #1025"
                                   Foreground="White"
                                   FontSize="22"/>

                    </StackPanel>

                </StackPanel>

                <Separator Margin="0,40,0,20"/>

                <Button Content="🏠 Dashboard"
                        Height="55"
                        FontSize="24"
                        Background="#A8C7F3"
                        BorderThickness="0"
                        Margin="0,5"/>

                <Button Content="📅 Visit Plan"
                        Height="50"
                        FontSize="22"
                        Margin="0,5"/>

                <Button Content="📍 Visited Places"
                        Height="50"
                        FontSize="22"
                        Margin="0,5"/>

                <Button Content="ℹ Heritage Information"
                        Height="50"
                        FontSize="22"
                        Margin="0,5"/>

                <Button Content="⚠ Rules &amp; Guidelines"
                        Height="50"
                        FontSize="22"
                        Margin="0,5"/>

                <Button Content="👤 Profile"
                        Height="50"
                        FontSize="22"
                        Margin="0,5"/>

                <Separator Margin="0,100,0,30"/>

                <TextBlock Text="SITE STATUS"
                           FontSize="26"
                           Foreground="White"/>

                <TextBlock Text="Status: Online"
                           FontSize="20"
                           Foreground="#90EE90"/>

            </StackPanel>

        </Border>

        
        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            
            <Border Background="#E5E5E8">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Cultural Heritage Site Management System"
                               FontSize="28"
                               VerticalAlignment="Center"
                               Margin="20,0"/>

                    <TextBlock Grid.Column="1"
                               Text="Thursday, July 12, 2026"
                               FontSize="24"
                               Margin="0,0,20,0"
                               VerticalAlignment="Center"/>

                </Grid>

            </Border>

            
            <StackPanel Grid.Row="1"
                        Margin="40,20">

                <TextBlock Text="VISITOR DASHBOARD"
                           FontSize="58"
                           FontWeight="Bold"
                           Foreground="#2F3042"/>

                <TextBlock Text="Welcome, Visitor #1025"
                           FontSize="26"/>

            </StackPanel>

            
            <Grid Grid.Row="2"
                  Margin="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="330"/>
                    <RowDefinition Height="250"/>
                </Grid.RowDefinitions>

                
                <Border Grid.Row="0"
                        Grid.Column="0"
                        Background="White"
                        CornerRadius="20"
                        Margin="10">

                    <Grid Margin="20">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>

                        <Ellipse Width="140"
                                 Height="140"
                                 Fill="#DCDCDC"
                                 VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="1">

                            <TextBlock Text="YOUR VISIT INFO"
                                       FontSize="30"
                                       FontWeight="SemiBold"/>

                            <TextBlock Text="Visitor ID: 1025"
                                       FontSize="26"
                                       Margin="0,30,0,0"/>

                            <TextBlock Text="Assigned Tour Guide: Alex Carter"
                                       FontSize="20"
                                       Margin="0,25,0,0"/>

                            <TextBlock Text="Entry Time: 09:15 AM"
                                       FontSize="20"/>

                            <TextBlock Text="Time Spent Inside: 2h 15m"
                                       FontSize="20"/>

                        </StackPanel>

                        <Border Grid.Column="2"
                                Width="150"
                                Height="150"
                                Background="#F0F0F0"
                                BorderBrush="Black"
                                BorderThickness="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                            <TextBlock Text="QR"
                                       FontSize="42"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>

                        </Border>

                    </Grid>

                </Border>

                
                <Border Grid.Row="0"
                        Grid.Column="1"
                        Background="White"
                        CornerRadius="20"
                        Margin="10">

                    <StackPanel Margin="20">

                        <TextBlock Text="SITE MAP"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>

                        <Canvas Height="220">

                            <Rectangle Width="250"
                                       Height="150"
                                       Stroke="Black"
                                       Canvas.Left="30"
                                       Canvas.Top="20"/>

                            <TextBlock Text="Museum"
                                       Canvas.Left="80"
                                       Canvas.Top="40"
                                       FontSize="18"/>

                            <TextBlock Text="Temple"
                                       Canvas.Left="170"
                                       Canvas.Top="90"
                                       FontSize="18"/>

                            <Ellipse Width="15"
                                     Height="15"
                                     Fill="Red"
                                     Canvas.Left="70"
                                     Canvas.Top="100"/>

                            <TextBlock Text="You Are Here"
                                       Canvas.Left="90"
                                       Canvas.Top="95"
                                       FontSize="18"/>

                        </Canvas>

                    </StackPanel>

                </Border>

                
                <Border Grid.Row="1"
                        Grid.Column="0"
                        Background="White"
                        CornerRadius="20"
                        Margin="10">

                    <Grid>

                        <Button Content="I'M LOST - SEND ALERT"
                                Width="650"
                                Height="110"
                                FontSize="36"
                                Foreground="White"
                                FontWeight="Bold"
                                Background="#E53935"
                                BorderThickness="0"/>

                    </Grid>

                </Border>

                
                <Border Grid.Row="1"
                        Grid.Column="1"
                        Background="White"
                        CornerRadius="20"
                        Margin="10">

                    <StackPanel Margin="20">

                        <TextBlock Text="SITE UPDATES"
                                   FontSize="30"
                                   FontWeight="SemiBold"/>

                        <TextBlock Text="Water station 2 is temporarily unavailable."
                                   FontSize="22"
                                   TextWrapping="Wrap"
                                   Margin="0,20,0,0"/>

                        <TextBlock Text="Special talk at 12:00 PM."
                                   FontSize="22"
                                   Margin="0,20,0,0"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Window>
