<Window x:Class="CulturalHeritageUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Visitor Interface" Height="800" Width="1400" 
        WindowStartupLocation="CenterScreen" 
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#33333C" Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="VISITOR INTERFACE" Foreground="White" FontSize="22" 
                           FontWeight="Light" Margin="25,30,25,20" Grid.Row="0"/>

                <StackPanel Orientation="Horizontal" Margin="25,10,25,30" Grid.Row="1">
                    <Border Width="40" Height="40" CornerRadius="20" BorderBrush="#888" BorderThickness="1.5">
                        <TextBlock Text="👤" Foreground="#888" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                    </Border>
                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Welcome" Foreground="#AAA" FontSize="14"/>
                        <TextBlock Text="Visitor #1025" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,10,0,0">

                    <StackPanel.Resources>
                        <Style TargetType="StackPanel" x:Key="MenuItemStyle">
                            <Setter Property="Orientation" Value="Horizontal"/>
                            <Setter Property="Margin" Value="25,8,25,8"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                        <Style TargetType="TextBlock" x:Key="MenuIconStyle">
                            <Setter Property="Foreground" Value="#AAA"/>
                            <Setter Property="FontSize" Value="18"/>
                            <Setter Property="Width" Value="30"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                        <Style TargetType="TextBlock" x:Key="MenuTextStyle">
                            <Setter Property="Foreground" Value="#AAA"/>
                            <Setter Property="FontSize" Value="18"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </StackPanel.Resources>

                    <Border BorderBrush="#444" BorderThickness="0,1,0,0" Margin="25,0,25,20"/>

                    <StackPanel Style="{StaticResource MenuItemStyle}">
                        <TextBlock Text="⌂" Style="{StaticResource MenuIconStyle}" FontSize="24" Margin="0,-5,0,0"/>
                        <TextBlock Text="Dashboard" Style="{StaticResource MenuTextStyle}"/>
                    </StackPanel>
                    <StackPanel Style="{StaticResource MenuItemStyle}">
                        <TextBlock Text="📅" Style="{StaticResource MenuIconStyle}"/>
                        <TextBlock Text="Visit Plan" Style="{StaticResource MenuTextStyle}"/>
                    </StackPanel>
                    <StackPanel Style="{StaticResource MenuItemStyle}">
                        <TextBlock Text="📍" Style="{StaticResource MenuIconStyle}"/>
                        <TextBlock Text="Visited Places" Style="{StaticResource MenuTextStyle}"/>
                    </StackPanel>
                    <StackPanel Style="{StaticResource MenuItemStyle}">
                        <TextBlock Text="ⓘ" Style="{StaticResource MenuIconStyle}"/>
                        <TextBlock Text="Heritage Information" Style="{StaticResource MenuTextStyle}"/>
                    </StackPanel>

                    <Border Background="#B2BED3" CornerRadius="8" Margin="15,5,15,5" Padding="10,8,10,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ⓘ" Foreground="#222" FontSize="18" Width="30" VerticalAlignment="Center"/>
                            <TextBlock Text="Rules &amp; Guidelines" Foreground="#111" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Style="{StaticResource MenuItemStyle}">
                        <TextBlock Text="👤" Style="{StaticResource MenuIconStyle}"/>
                        <TextBlock Text="Profile" Style="{StaticResource MenuTextStyle}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="25,0,25,30">
                    <Border BorderBrush="#444" BorderThickness="0,1,0,0" Margin="0,0,0,20"/>
                    <TextBlock Text="SITE STATUS" Foreground="#AAA" FontSize="16"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Status:" Foreground="#888" FontSize="16" Margin="0,0,5,0"/>
                        <TextBlock Text="Online" Foreground="#6C8E99" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#FAF4F7">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#E5DFE3">
                <TextBlock Text="Cultural Heritage Site Management System" VerticalAlignment="Center" Margin="20,0,0,0" FontSize="16" Foreground="#333"/>
                <TextBlock Text="Thursday, July 12, 2026, 1:30 PM" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0" FontSize="16" Foreground="#333"/>
            </Grid>

            <Grid Grid.Row="1" Margin="40,30,40,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,25">
                    <TextBlock Text="RULES &amp; GUIDELINES" FontSize="36" FontWeight="Bold" Foreground="#444246"/>
                    <TextBlock Text="Welcome, Visitor #1025" FontSize="20" Foreground="#222" Margin="0,5,0,0"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="12" Margin="0,0,15,0" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="VISITOR RULES &amp; SAFETY INSTRUCTIONS" FontSize="22" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#333" Grid.Row="0" Margin="0,0,0,25"/>

                            <StackPanel Grid.Row="1">
                                <Grid Margin="0,0,0,25">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="1" FontSize="22" VerticalAlignment="Center" Foreground="#333"/>
                                    <Border Grid.Column="1" Width="70" Height="70" Background="#111" CornerRadius="8" HorizontalAlignment="Left">
                                        <TextBlock Text="🗺️" Foreground="White" FontSize="35" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" TextWrapping="Wrap" FontSize="16" Foreground="#222" VerticalAlignment="Center">
                                        <Run FontWeight="SemiBold" Text="Site Map Tracking: "/>
                                        <Run Text="Use provided map boundaries for safety and preservation."/>
                                    </TextBlock>
                                </Grid>

                                <Grid Margin="0,0,0,25">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="2" FontSize="22" VerticalAlignment="Center" Foreground="#333"/>
                                    <Border Grid.Column="1" Width="70" Height="70" Background="#111" CornerRadius="8" HorizontalAlignment="Left">
                                        <TextBlock Text="📹" Foreground="White" FontSize="35" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" TextWrapping="Wrap" FontSize="16" Foreground="#222" VerticalAlignment="Center">
                                        <Run FontWeight="SemiBold" Text="CCTV Monitoring: "/>
                                        <Run Text="The site is under 24/7 video surveillance."/>
                                    </TextBlock>
                                </Grid>

                                <Grid Margin="0,0,0,25">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="3" FontSize="22" VerticalAlignment="Center" Foreground="#333"/>
                                    <Border Grid.Column="1" Width="70" Height="70" Background="#111" CornerRadius="8" HorizontalAlignment="Left">
                                        <TextBlock Text="🗑️" Foreground="White" FontSize="35" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" TextWrapping="Wrap" FontSize="16" Foreground="#222" VerticalAlignment="Center">
                                        <Run FontWeight="SemiBold" Text="Do Not Litter: "/>
                                        <Run Text="Dispose of waste only in provided bins."/>
                                    </TextBlock>
                                </Grid>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="4" FontSize="22" VerticalAlignment="Center" Foreground="#333"/>
                                    <Border Grid.Column="1" Width="70" Height="70" Background="#111" CornerRadius="8" HorizontalAlignment="Left">
                                        <TextBlock Text="✋" Foreground="White" FontSize="35" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="2" TextWrapping="Wrap" FontSize="16" Foreground="#222" VerticalAlignment="Center">
                                        <Run FontWeight="SemiBold" Text="Preservation: "/>
                                        <Run Text="Do not touch artifacts, inscriptions, or structures."/>
                                    </TextBlock>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="12" Margin="15,0,0,0" Padding="25">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.05" BlurRadius="10" ShadowDepth="2"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="EMERGENCY PROCEDURES &amp; KEY GUIDELINES" FontSize="22" TextWrapping="Wrap" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,20"/>

                            <Border Background="#E6E9E6" BorderBrush="#C2C2C2" BorderThickness="2" CornerRadius="8" Height="170" Margin="0,0,0,25">
                                <Grid>
                                    <Border Background="#2E7D32" Width="60" Height="30" Margin="20,20,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                    <Border Background="#388E3C" Width="100" Height="10" Margin="90,30,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                    <Border Background="#43A047" Width="20" Height="20" Margin="200,20,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                                    <Border Background="#C62828" Width="40" Height="40" Margin="0,0,20,20" HorizontalAlignment="Right" VerticalAlignment="Bottom" CornerRadius="4">
                                        <TextBlock Text="🧯" Foreground="White" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <Border Background="#2E7D32" Width="40" Height="40" Margin="0,20,20,0" HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="4">
                                        <TextBlock Text="✚" Foreground="White" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                                    </Border>

                                    <Rectangle Fill="#D32F2F" Height="3" Width="120" Margin="100,50,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                    <Rectangle Fill="#D32F2F" Width="3" Height="60" Margin="220,50,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                                    <Border Background="#2E7D32" Width="35" Height="35" Margin="10,0,0,20" HorizontalAlignment="Left" VerticalAlignment="Bottom" CornerRadius="4">
                                        <TextBlock Text="🚪" Foreground="White" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>

                            <TextBlock Text="DOS &amp; DON'TS" FontSize="18" FontWeight="Bold" Foreground="#111" Margin="0,0,0,5"/>
                            <TextBlock FontSize="16" Foreground="#333" Margin="0,0,0,25" LineHeight="24">
                                Do: Stay on marked paths<LineBreak/>
                                Don't: Climb structures<LineBreak/>
                                Don't: Climb enclosures and structures
                            </TextBlock>

                            <TextBlock Text="EMERGENCY PROCEDURES" FontSize="18" FontWeight="Bold" Foreground="#111" Margin="0,0,0,5"/>
                            <TextBlock FontSize="16" Foreground="#333" LineHeight="24">
                                Follow staff directions<LineBreak/>
                                Follow staff event assistance<LineBreak/>
                                Emergency Contact: (555) 123-4567
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
