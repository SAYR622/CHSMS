<Window x:Class="admin_ui_and_guider_new.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:admin_ui_and_guider_new"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.Resources>
        
        <Style x:Key="RoundedButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="12"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid RenderTransformOrigin="0.5,0.5" Height="434" VerticalAlignment="Top">

        
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#64CCF1" Offset="0"/>
                <GradientStop Color="#A8E6FF" Offset="0.5"/>
                <GradientStop Color="#FFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform/>
                <SkewTransform/>
                <RotateTransform Angle="-0.008"/>
                <TranslateTransform/>
            </TransformGroup>
        </Grid.RenderTransform>

        <Grid Margin="8,17,-9,13">

            <TextBox HorizontalAlignment="Left"
                     Height="38"
                     Margin="186,123,0,0"
                     TextWrapping="Wrap"
                     Text="Username"
                     VerticalAlignment="Top"
                     Width="452"
                     FontSize="26"
                     BorderBrush="{x:Null}"
                     Background="#FFF6F6F6"
                     Foreground="DarkGray"
                     TextAlignment="Center"
                     TextChanged="TextBox_TextChanged"/>

            <TextBox HorizontalAlignment="Left"
                     Height="38"
                     Margin="190,193,0,0"
                     TextWrapping="Wrap"
                     Text="Password"
                     VerticalAlignment="Top"
                     Width="451"
                     FontSize="26"
                     BorderBrush="{x:Null}"
                     Background="#FFF6F6F6"
                     Foreground="DarkGray"
                     TextAlignment="Center"/>

            <Button Content="Login"
                    HorizontalAlignment="Left"
                    Height="50"
                    Margin="345,290,0,0"
                    VerticalAlignment="Top"
                    Width="134"
                    Background="#64CCF1"
                    Foreground="White"
                    FontFamily="Arial"
                    FontSize="20"
                    BorderThickness="0"
                    Style="{StaticResource RoundedButtonStyle}"/>

        </Grid>

    </Grid>
</Window>
