<Window x:Class="VisitorPlanUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Visitor Plan"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#F4F0F5">

    <Grid>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1F2333"/>
                    <GradientStop Color="#38405A" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel Margin="30">

                <TextBlock Text="VISITOR INTERFACE"
                           FontSize="42"
                           Foreground="White"
                           Margin="0,0,0,50"/>

                <StackPanel Orientation="Horizontal">

                    <Ellipse Width="70"
                             Height="70"
                             Fill="#E0E0E0"/>

                    <StackPanel Margin="15,5,0,0">

                        <TextBlock Text="Welcome"
                                   FontSize="22"
                                   Foreground="White"/>

                        <TextBlock Text="Visitor #1025"
                                   FontSize="22"
                                   Foreground="White"/>

                    </StackPanel>

                </StackPanel>

                <Separator Margin="0,40,0,20"/>

                <Button Content="Dashboard"
                        Height="55"
                        FontSize="22"
                        Margin="0,5"/>

                <Button Content="Visit Plan"
                        Height="55"
                        FontSize="22"
                        Background="#A8C6F0"
                        FontWeight="Bold"
                        Margin="0,5"/>

                <Button Content="Visited Places"
                        Height="55"
                        FontSize="22"
                        Margin="0,5"/>

                <Button Content="Heritage Information"
                        Height="55"
                        FontSize="22"
                        Margin="0,5"/>

                <Button Content="Rules &amp; Guidelines"
                        Height="55"
                        FontSize="22"
                        Margin="0,5"/>

                <Button Content="Profile"
                        Height="55"
                        FontSize="22"
                        Margin="0,5"/>

                <Separator Margin="0,120,0,30"/>

                <TextBlock Text="SITE STATUS"
                           FontSize="28"
                           Foreground="White"/>

                <TextBlock Text="Status: Online"
                           FontSize="22"
                           Foreground="#8AE68A"/>

            </StackPanel>

        </Border>

        
        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="120"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            
            <Border Background="#E2E2E6">

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Cultural Heritage Site Management System"
                               FontSize="30"
                               VerticalAlignment="Center"
                               Margin="20,0"/>

                    <TextBlock Grid.Column="1"
                               Text="Thursday, July 12, 2026"
                               FontSize="24"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"/>

                </Grid>

            </Border>

            
            <StackPanel Grid.Row="1"
                        Margin="40,20">

                <TextBlock Text="VISITOR PLAN"
                           FontSize="56"
                           FontWeight="Bold"
                           Foreground="#2C2D40"/>

                <TextBlock Text="Welcome, Visitor #1025"
                           FontSize="24"/>

            </StackPanel>

            
            <Grid Grid.Row="2"
                  Margin="20">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                
                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="20"
                        Margin="10">

                    <StackPanel Margin="20">

                        <TextBlock Text="SCHEDULED VISIT ROUTE &amp; TIMELINE"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20"/>

                        <StackPanel>

                            <TextBlock Text="1. Arrival &amp; Entry (Main Gate) - 09:15 AM"
                                       FontSize="22"
                                       Margin="0,10"/>

                            <TextBlock Text="2. Museum Tour - 09:25 AM"
                                       FontSize="22"
                                       Margin="0,10"/>

                            <TextBlock Text="3. Temple Complex - 10:10 AM"
                                       FontSize="22"
                                       Margin="0,10"/>

                            <TextBlock Text="4. Ancient Bath Site - 10:40 AM"
                                       FontSize="22"
                                       Margin="0,10"/>

                            <TextBlock Text="5. Sculpture Garden - 11:05 AM"
                                       FontSize="22"
                                       Margin="0,10"/>

                            <TextBlock Text="6. Gift Shop / Exit - 11:25 AM"
                                       FontSize="22"
                                       Margin="0,10"/>

                        </StackPanel>

                    </StackPanel>

                </Border>

                
                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="20"
                        Margin="10">

                    <StackPanel Margin="20">

                        <TextBlock Text="ROUTE MAP PREVIEW"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20"/>

                        <Canvas Height="450">

                            <Rectangle Width="320"
                                       Height="220"
                                       Stroke="Black"
                                       StrokeThickness="2"
                                       Canvas.Left="20"
                                       Canvas.Top="20"/>

                            <TextBlock Text="Museum"
                                       FontSize="24"
                                       Canvas.Left="90"
                                       Canvas.Top="50"/>

                            <TextBlock Text="Temple Complex"
                                       FontSize="22"
                                       Canvas.Left="180"
                                       Canvas.Top="140"/>

                            <Ellipse Width="15"
                                     Height="15"
                                     Fill="Red"
                                     Canvas.Left="60"
                                     Canvas.Top="180"/>

                            <TextBlock Text="You Are Here"
                                       FontSize="22"
                                       Canvas.Left="85"
                                       Canvas.Top="170"/>

                        </Canvas>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Window>
