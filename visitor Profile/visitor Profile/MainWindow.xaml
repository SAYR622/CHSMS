<Window x:Class="CulturalHeritageUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Visitor Interface" Height="800" Width="1400" 
        WindowStartupLocation="CenterScreen" 
        FontFamily="Segoe UI">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#33333C" Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="VISITOR INTERFACE" Foreground="White" FontSize="22" 
                           FontWeight="Light" Margin="25,30,25,20" Grid.Row="0"/>

                <StackPanel Orientation="Horizontal" Margin="25,10,25,30" Grid.Row="1">
                    <Border Width="40" Height="40" CornerRadius="20" BorderBrush="#888" BorderThickness="1.5">
                        <TextBlock Text="👤" Foreground="#888" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                    </Border>
                    <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Welcome" Foreground="#AAA" FontSize="14"/>
                        <TextBlock Text="Visitor #1025" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,10,0,0">

                    <StackPanel.Resources>
                        <Style TargetType="StackPanel" x:Key="MenuItemStyle">
                            <Setter Property="Orientation" Value="Horizontal"/>
                            <Setter Property="Margin" Value="25,8,25,8"/>
                            <Setter Property="Cursor" Value="Hand"/>
                        </Style>
                        <Style TargetType="TextBlock" x:Key="MenuIconStyle">
                            <Setter Property="Foreground" Value="#AAA"/>
                            <Setter Property="FontSize" Value="18"/>
                            <Setter Property="Width" Value="30"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                        <Style TargetType="TextBlock" x:Key="MenuTextStyle">
                            <Setter Property="Foreground" Value="#AAA"/>
                            <Setter Property="FontSize" Value="18"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </StackPanel.Resources>

                    <Border BorderBrush="#444" BorderThickness="0,1,0,0" Margin="25,0,25,20"/>

                    <StackPanel Style="{StaticResource MenuItemStyle}">
                        <TextBlock Text="⌂" Style="{StaticResource MenuIconStyle}" FontSize="24" Margin="0,-5,0,0"/>
                        <TextBlock Text="Dashboard" Style="{StaticResource MenuTextStyle}"/>
                    </StackPanel>
                    <StackPanel Style="{StaticResource MenuItemStyle}">
                        <TextBlock Text="📅" Style="{StaticResource MenuIconStyle}"/>
                        <TextBlock Text="Visit Plan" Style="{StaticResource MenuTextStyle}"/>
                    </StackPanel>
                    <StackPanel Style="{StaticResource MenuItemStyle}">
                        <TextBlock Text="📍" Style="{StaticResource MenuIconStyle}"/>
                        <TextBlock Text="Visited Places" Style="{StaticResource MenuTextStyle}"/>
                    </StackPanel>
                    <StackPanel Style="{StaticResource MenuItemStyle}">
                        <TextBlock Text="ⓘ" Style="{StaticResource MenuIconStyle}"/>
                        <TextBlock Text="Heritage Information" Style="{StaticResource MenuTextStyle}"/>
                    </StackPanel>
                    <StackPanel Style="{StaticResource MenuItemStyle}">
                        <TextBlock Text="⚠" Style="{StaticResource MenuIconStyle}"/>
                        <TextBlock Text="Rules &amp; Guidelines" Style="{StaticResource MenuTextStyle}"/>
                    </StackPanel>

                    <Border Background="#B2BED3" CornerRadius="8" Margin="15,5,15,5" Padding="10,8,10,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" Foreground="#222" FontSize="18" Width="30" VerticalAlignment="Center"/>
                            <TextBlock Text="Profile" Foreground="#111" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Row="3" Margin="25,0,25,30">
                    <Border BorderBrush="#444" BorderThickness="0,1,0,0" Margin="0,0,0,20"/>
                    <TextBlock Text="SITE STATUS" Foreground="#AAA" FontSize="16"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Status:" Foreground="#888" FontSize="16" Margin="0,0,5,0"/>
                        <TextBlock Text="Online" Foreground="#6C8E99" FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Background="#FAF4F7">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#E5DFE3">
                <TextBlock Text="Cultural Heritage Site Management System" VerticalAlignment="Center" Margin="20,0,0,0" FontSize="16" Foreground="#333"/>
                <TextBlock Text="Thursday, July 12, 2026, 1:30 PM" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,20,0" FontSize="16" Foreground="#333"/>
            </Grid>

            <Grid Grid.Row="1" Margin="40,30,40,40">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="VISITOR PROFILE" FontSize="36" FontWeight="Bold" Foreground="#444246"/>
                </StackPanel>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.Resources>
                        <Style TargetType="Border" x:Key="CardStyle">
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="CornerRadius" Value="12"/>
                            <Setter Property="Padding" Value="25"/>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Black" Opacity="0.06" BlurRadius="10" ShadowDepth="2"/>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style TargetType="TextBlock" x:Key="CardTitleStyle">
                            <Setter Property="FontSize" Value="20"/>
                            <Setter Property="FontWeight" Value="Medium"/>
                            <Setter Property="Foreground" Value="#222"/>
                            <Setter Property="Margin" Value="0,0,0,15"/>
                        </Style>
                    </Grid.Resources>

                    <Border Style="{StaticResource CardStyle}" Grid.Row="0" Grid.Column="0" Margin="0,0,10,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="PROFILE OVERVIEW" Style="{StaticResource CardTitleStyle}" Grid.Row="0"/>

                            <StackPanel Orientation="Horizontal" Grid.Row="1">
                                <Border Width="80" Height="80" CornerRadius="40" Background="#E0CDCD" Margin="0,0,20,0" BorderBrush="#C4A8A8" BorderThickness="2">
                                    <TextBlock Text="👩🏽" FontSize="45" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-5,0,0"/>
                                </Border>

                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Jane Doe" FontSize="22" Foreground="#333" Margin="0,0,0,5"/>
                                    <TextBlock Text="Visitor ID: 1025" FontSize="18" Foreground="#222" Margin="0,0,0,2"/>
                                    <TextBlock Text="Status: Registered Account" FontSize="18" Foreground="#222"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Grid.Row="0" Grid.Column="1" Margin="10,0,0,20">
                        <StackPanel>
                            <TextBlock Text="CONTACT INFORMATION" Style="{StaticResource CardTitleStyle}"/>
                            <TextBlock Text="Phone: +1 (555) 123-4567" FontSize="20" Foreground="#222" Margin="0,0,0,10"/>
                            <TextBlock Text="Email: jane.d@visitor.org" FontSize="20" Foreground="#222"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Grid.Row="1" Grid.Column="0" Margin="0,0,10,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="TICKET &amp; ENTRY" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Adult Day Pass" FontSize="20" Foreground="#222" Margin="0,0,0,10"/>
                                <TextBlock Text="Valid: July 12, 2026" FontSize="20" Foreground="#222"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Border BorderBrush="Black" BorderThickness="2" Padding="2" Background="White" Width="90" Height="90" Margin="0,0,0,5">
                                    <UniformGrid Rows="4" Columns="4">
                                        <Rectangle Fill="Black" Margin="1"/>
                                        <Rectangle Fill="Black" Margin="1"/>
                                        <Rectangle Fill="White" Margin="1"/>
                                        <Rectangle Fill="Black" Margin="1"/>
                                        <Rectangle Fill="Black" Margin="1"/>
                                        <Rectangle Fill="White" Margin="1"/>
                                        <Rectangle Fill="Black" Margin="1"/>
                                        <Rectangle Fill="White" Margin="1"/>
                                        <Rectangle Fill="White" Margin="1"/>
                                        <Rectangle Fill="Black" Margin="1"/>
                                        <Rectangle Fill="Black" Margin="1"/>
                                        <Rectangle Fill="Black" Margin="1"/>
                                        <Rectangle Fill="Black" Margin="1"/>
                                        <Rectangle Fill="White" Margin="1"/>
                                        <Rectangle Fill="Black" Margin="1"/>
                                        <Rectangle Fill="White" Margin="1"/>
                                    </UniformGrid>
                                </Border>
                                <TextBlock Text="YOUR SITE ENTRY QR" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Grid.Row="1" Grid.Column="1" Margin="10,0,0,20">
                        <StackPanel>
                            <TextBlock Text="TOUR ASSIGNMENT" Style="{StaticResource CardTitleStyle}"/>
                            <TextBlock Text="Assigned Guide: Alex Carter" FontSize="20" Foreground="#222" Margin="0,0,0,10"/>
                            <TextBlock Text="Tour Group: Temple Complex Deep Dive" FontSize="20" Foreground="#222"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="PREFERENCES &amp; ACCESSIBILITY" Style="{StaticResource CardTitleStyle}"/>
                            <TextBlock Text="Language: English" FontSize="20" Foreground="#222" Margin="0,0,0,10"/>
                            <TextBlock Text="Accessibility: Wheelchair Accessible Paths" FontSize="20" Foreground="#222"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2" Grid.Column="1" Margin="10,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                        </Grid.RowDefinitions>

                        <Button Grid.Row="0" Margin="0,0,0,10" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border BorderBrush="#8DA6C6" BorderThickness="3" Background="White" CornerRadius="25" Effect="{x:Null}">
                                        <TextBlock Text="EDIT PROFILE" Foreground="#6C8BB8" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Row="1" Margin="0,10,0,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="#C63E3A" BorderBrush="#A93330" BorderThickness="0,0,0,4" CornerRadius="25">
                                        <TextBlock Text="LOG OUT" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
