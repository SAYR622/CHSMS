<Window x:Class="MuseumAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Museum Admin Dashboard"
        Height="900"
        Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F7">

    <Grid>

        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        
        <Border Grid.Column="0"
                Background="#263445">

            <DockPanel>

                <Border DockPanel.Dock="Bottom"
                        Margin="20">

                    <Button Content="Settings"
                            Height="50"
                            FontSize="20"/>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">

                        <TextBlock Text="ADMIN INTERFACE"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   Margin="0,10,0,30"/>

                        <Separator Background="#5B6775"
                                   Margin="0,0,0,20"/>

                        <Button Height="55"
                                HorizontalContentAlignment="Left"
                                Padding="15,0,0,0"
                                FontSize="22"
                                Content="Dashboard"
                                Background="#A9D2F5"
                                BorderThickness="0"
                                Margin="0,0,0,15"/>

                        <Expander Header="Artifact Inventory"
                                  Foreground="White"
                                  FontSize="18"
                                  Margin="0,5">

                            <StackPanel Margin="20,10">
                                <Button Content="Add Artifact" Margin="0,5"/>
                                <Button Content="Update Artifact" Margin="0,5"/>
                                <Button Content="Delete Artifact" Margin="0,5"/>
                                <Button Content="View Artifacts" Margin="0,5"/>
                            </StackPanel>

                        </Expander>

                        <Expander Header="Visitor Management"
                                  Foreground="White"
                                  FontSize="18"
                                  Margin="0,5">

                            <StackPanel Margin="20,10">
                                <Button Content="Register Visitor" Margin="0,5"/>
                                <Button Content="View Visitors" Margin="0,5"/>
                            </StackPanel>

                        </Expander>

                        <Expander Header="Tour Guide Management"
                                  Foreground="White"
                                  FontSize="18"
                                  Margin="0,5">

                            <StackPanel Margin="20,10">
                                <Button Content="Assign Guides" Margin="0,5"/>
                                <Button Content="Guide Schedule" Margin="0,5"/>
                                <Button Content="Guide Availability" Margin="0,5"/>
                            </StackPanel>

                        </Expander>

                        <Button Content="Analytics Reports"
                                Height="45"
                                Margin="0,15,0,0"/>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>

        </Border>

        
        <Grid Grid.Column="1"
              Margin="30">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            
            <Grid Grid.Row="0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="DASHBOARD OVERVIEW"
                               FontSize="42"
                               FontWeight="Bold"/>

                    <TextBlock Text="Welcome Admin"
                               FontSize="22"
                               Foreground="Gray"/>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Button Width="45"
                            Height="45"
                            Margin="0,0,15,0"
                            Content="🔔"/>

                    <Border Width="45"
                            Height="45"
                            CornerRadius="22"
                            Background="#D9D9D9"/>

                    <TextBlock Text="Admin User"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               FontSize="18"/>

                </StackPanel>

            </Grid>

            
            <UniformGrid Grid.Row="1"
                         Columns="4"
                         Margin="0,30,0,20">

                <Border CornerRadius="15"
                        Margin="10"
                        Background="White">

                    <StackPanel Margin="20">
                        <TextBlock Text="Total Visitors Today"
                                   FontSize="20"/>
                        <TextBlock Text="32,627"
                                   FontSize="42"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Trend Increased"
                                   Foreground="Gray"/>
                    </StackPanel>

                </Border>

                <Border CornerRadius="15"
                        Margin="10"
                        Background="White">

                    <StackPanel Margin="20">
                        <TextBlock Text="Available Guides"
                                   FontSize="20"/>
                        <TextBlock Text="2"
                                   FontSize="42"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Status Available"
                                   Foreground="Gray"/>
                    </StackPanel>

                </Border>

                <Border CornerRadius="15"
                        Margin="10"
                        Background="White">

                    <StackPanel Margin="20">
                        <TextBlock Text="Total Artifacts"
                                   FontSize="20"/>
                        <TextBlock Text="1966"
                                   FontSize="42"
                                   FontWeight="Bold"/>
                    </StackPanel>

                </Border>

                <Border CornerRadius="15"
                        Margin="10"
                        Background="White">

                    <StackPanel Margin="20">
                        <TextBlock Text="Upcoming Tours"
                                   FontSize="20"/>
                        <TextBlock Text="5"
                                   FontSize="42"
                                   FontWeight="Bold"/>
                        <TextBlock Text="For Today"
                                   Foreground="Gray"/>
                    </StackPanel>

                </Border>

            </UniformGrid>

            
            <Grid Grid.Row="2">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                
                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="15"
                        Margin="10">

                    <StackPanel Margin="20">

                        <TextBlock Text="Visitor Trends (Last 7 Days)"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20"/>

                        <Canvas Width="460"
                                Height="220">

                            <Polyline Stroke="#4C78A8"
                                      StrokeThickness="4"
                                      Points="20,200 90,120 160,180 230,60 300,160 370,100 440,30"/>

                        </Canvas>

                    </StackPanel>

                </Border>

              
                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="15"
                        Margin="10">

                    <StackPanel Margin="20">

                        <TextBlock Text="RECENT ACTIVITY LOGS"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,20"/>

                        <DataGrid AutoGenerateColumns="False"
                                  Height="250"
                                  CanUserAddRows="False"
                                  IsReadOnly="True">

                            <DataGrid.Columns>

                                <DataGridTextColumn Header="Timestamp"
                                                    Width="*"/>

                                <DataGridTextColumn Header="Action"
                                                    Width="1.5*"/>

                                <DataGridTextColumn Header="User"
                                                    Width="*"/>

                            </DataGrid.Columns>

                        </DataGrid>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</Window>

